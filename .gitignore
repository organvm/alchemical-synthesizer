node_modules/
.DS_Store
*.swp
*.wav
*.aiff
*.mp4
*.mov
*.webm

# IDE / editor
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Environment
.env
.env.local

# Logs
*.log

# Build artifacts
*.o
*.so
build/
dist/

# SuperCollider temp
*.scx
synthdefs/

# Forge pipeline outputs (stems, recipes, rendered tracks) + demucs env.
# Ignore the runtime output only — the Forge lane itself (ORGAN.md, and tools as
# they consolidate here) is tracked. See ORGANS.md.
forge/stems/
forge/recipes/
forge/out/
out/
.venv-demucs/

# Ephemeral agent worktrees — never track their gitlinks (a git add sweep would
# otherwise record .claude/worktrees/<name> as a broken 160000 gitlink).
.claude/worktrees/

# Python
__pycache__/
*.pyc

# Cloudflare wrangler local cache (account cache, dev state) — never track.
.wrangler/

# Override global gitignore's `public/` rule (Gatsby)
!brahma/web/public/
